APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/broker_salud
SECRET_KEY=changeme_super_secret_key
QR_SECRET=changeme_qr_secret
SERVICE_TOKEN=changeme_internal_service_token
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
REDIS_URL=redis://localhost:6379/0
JOB_QUEUE_NAME=celdoctor:jobs
JOB_RETRY_LIMIT=3
PAYMENT_MANUAL_ENABLED=false
MERCADOPAGO_WEBHOOK_SECRET=changeme_mercadopago_webhook_secret
MERCADOPAGO_WEBHOOK_TOLERANCE_SECONDS=300
BACKUP_OUTPUT_DIR=backups
BACKUP_FILE_PREFIX=celdoctor
ENABLE_DOCS=true
ENABLE_REDOC=true
QR_DEFAULT_BENEFIT_TYPE=farmacia
FARMACIA_DESCUENTO_PORCENTAJE=40
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
WEB_CONCURRENCY=2
UVICORN_KEEP_ALIVE=30
